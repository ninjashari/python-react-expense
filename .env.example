# Postgres connection string. Use a Neon pooled connection string in production;
# for local development you can instead point this at a local Postgres instance
# (e.g. postgresql://postgres:postgres@localhost:5432/ledgerly) and it will
# automatically use a standard TCP connection instead of Neon's HTTP driver.
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Secret used to sign session JWTs. Must be at least 32 characters.
# Generate one with: openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
