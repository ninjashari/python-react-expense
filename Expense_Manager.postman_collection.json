  "variable": [
    { "key": "base_url", "value": "http://localhost:8001", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "account_id", "value": "", "type": "string" },
    { "key": "transaction_id", "value": "", "type": "string" },
    { "key": "payee_id", "value": "", "type": "string" },
